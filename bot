async def delete_all_previous_messages(chat_id, context):
    try:
        start_msg_id = start_message_ids.get(chat_id)
        if chat_id in user_message_history and user_message_history[chat_id]:
            for msg_id in user_message_history[chat_id]:
                if msg_id == start_msg_id:
                    continue
                try:
                    await context.bot.delete_message(chat_id=chat_id, message_id=msg_id)
                except Exception:
                    pass
            user_message_history[chat_id] = [start_msg_id] if start_msg_id else []
        if chat_id in user_input_history and user_input_history[chat_id]:
            for msg_id in user_input_history[chat_id]:
                try:
                    await context.bot.delete_message(chat_id=chat_id, message_id=msg_id)
                except Exception:
                    pass
            user_input_history[chat_id] = []
    except Exception as e:
        logger.error(f"Ошибка при удалении сообщений: {e}")


def add_message_to_history(chat_id, message_id):
    if chat_id not in user_message_history:
        user_message_history[chat_id] = []
    user_message_history[chat_id].append(message_id)
    if len(user_message_history[chat_id]) > 20:
        start_msg_id = start_message_ids.get(chat_id)
        if start_msg_id and start_msg_id in user_message_history[chat_id]:
            filtered = [start_msg_id] + [m for m in user_message_history[chat_id][-19:] if m != start_msg_id]
            user_message_history[chat_id] = filtered
        else:
            user_message_history[chat_id] = user_message_history[chat_id][-20:]


def add_user_input_to_history(chat_id, message_id):
    if chat_id not in user_input_history:
        user_input_history[chat_id] = []
    user_input_history[chat_id].append(message_id)
    if len(user_input_history[chat_id]) > 10:
        user_input_history[chat_id] = user_input_history[chat_id][-10:]


async def delete_only_bot_messages(chat_id, context):
    try:
        start_msg_id = start_message_ids.get(chat_id)
        if chat_id in user_message_history and user_message_history[chat_id]:
            for msg_id in user_message_history[chat_id]:
                if msg_id == start_msg_id:
                    continue
                try:
                    await context.bot.delete_message(chat_id=chat_id, message_id=msg_id)
                except Exception:
                    pass
            user_message_history[chat_id] = [start_msg_id] if start_msg_id else []
    except Exception as e:
        logger.error(f"Ошибка при удалении сообщений бота: {e}")


def format_price(price):
    return f"{price:,}".replace(",", " ") + " ₽"


