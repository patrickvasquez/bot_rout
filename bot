async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()

    user_id = query.from_user.id
    chat_id = query.message.chat.id
    data = query.data

    # Главное меню
    if data == 'main_menu':
        await delete_only_bot_messages(chat_id, context)
        await show_main_menu(update, context)
        return

    if data == 'noop':
        return

    # Вкладка «Модели»
    if data == 'tab_models':
        await delete_only_bot_messages(chat_id, context)
        await show_models_tab(chat_id, context)
        return

    # Карточка роутера
    if data.startswith('router_'):
        router_id = data.replace('router_', '')
        await delete_only_bot_messages(chat_id, context)
        await show_router_card(chat_id, context, router_id)
        return

    # Заказ
    if data.startswith('order_'):
        router_id = data.replace('order_', '')
        await delete_only_bot_messages(chat_id, context)
        await handle_order(chat_id, context, router_id)
        return

    # Вкладка «Ключ для роутера»
    if data == 'tab_key':
        await delete_only_bot_messages(chat_id, context)
        await show_key_tab(chat_id, context)
        return

    # Вкладка «О нас»
    if data == 'tab_about':
        await delete_only_bot_messages(chat_id, context)
        await show_about_tab(chat_id, context)
        return


