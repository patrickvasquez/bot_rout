    features_text = "\n".join(f"  • {f}" for f in router["features"])
    included_text = "\n".join(f"  ✔️ {s}" for s in router["included_in_price"])
    services_text = "\n".join(f"  ✅ {s}" for s in router["services"])

    text = (
