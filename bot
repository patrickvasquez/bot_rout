    await delete_only_bot_messages(chat_id, context)
    message = await context.bot.send_message(
        chat_id=chat_id,
        text="Используй кнопки меню для навигации 👇",
        parse_mode='HTML',
        reply_markup=get_main_menu()
    )
    add_message_to_history(chat_id, message.message_id)


